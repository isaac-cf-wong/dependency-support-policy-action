{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "config:best-practices",
        ":semanticCommitTypeAll(chore)"
    ],
    "dependencyDashboard": true,
    "dependencyDashboardTitle": "Dependency Dashboard",
    "pre-commit": {
        "enabled": true
    },
    "lockFileMaintenance": {
        "enabled": false
    },
    "packageRules": [
        {
            "matchManagers": ["pep621"],
            "matchDepTypes": ["project.dependencies"],
            "description": "Runtime lower bounds are owned by the dependency-support-policy (SPEC 0) workflow.",
            "enabled": false
        },
        {
            "matchManagers": ["pep621"],
            "matchDepTypes": ["dependency-groups"],
            "groupName": "dev tools",
            "automerge": true,
            "automergeType": "pr",
            "automergeStrategy": "squash"
        },
        {
            "matchManagers": ["github-actions"],
            "enabled": false
        },
        {
            "matchManagers": ["pre-commit"],
            "automerge": true,
            "automergeType": "pr",
            "automergeStrategy": "squash"
        },
        {
            "matchFileNames": ["tests/data/**"],
            "enabled": false
        },
        {
            "matchDatasources": ["python-version"],
            "description": "The requires-python floor is owned by the dependency-support-policy (SPEC 0) workflow.",
            "enabled": false
        }
    ],
    "rangeStrategy": "bump"
}
